<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1C1C1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="欢迎使用"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请输入你的 DeepSeek API Key"
            android:textSize="16sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etApiKey"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_bg"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:hint="请输入你的 DeepSeek API Key"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btnVerify"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="验证并继续"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_bg"
            android:layout_marginTop="24dp"/>

        <ProgressBar
            android:id="@+id/progressVerify"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvApiStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF6B6B"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:id="@+id/llCustomize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="32dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自定义头像（可选）"
                android:textSize="16sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivAiAvatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_ai_avatar"
                        android:scaleType="centerCrop"
                        android:clickable="true"/>

                    <Button
                        android:id="@+id/btnAiAvatar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI头像"
                        android:textSize="12sp"
                        android:background="@drawable/btn_bg"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_user_avatar"
                        android:scaleType="centerCrop"
                        android:clickable="true"/>

                    <Button
                        android:id="@+id/btnUserAvatar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="用户头像"
                        android:textSize="12sp"
                        android:background="@drawable/btn_bg"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自定义背景（可选）"
                android:textSize="16sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnBackground"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择背景图片"
                android:background="@drawable/btn_bg"/>

            <Button
                android:id="@+id/btnFinish"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:text="完成，进入分身"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_bg"
                android:layout_marginTop="24dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
